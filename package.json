{
  "name": "swe-auction",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --parallel --filter @swe-auction/api --filter @swe-auction/web --filter @swe-auction/worker dev",
    "build": "pnpm -r --sort --if-present build",
    "lint": "pnpm -r --sort --if-present lint",
    "typecheck": "pnpm -r --sort --if-present typecheck",
    "test": "pnpm -r --sort --if-present test",
    "postinstall": "node ./scripts/postinstall.mjs",
    "db:migrate:dev": "pnpm --filter @swe-auction/api db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @swe-auction/api db:migrate:deploy",
    "db:reset": "pnpm --filter @swe-auction/api db:reset",
    "db:seed": "pnpm --filter @swe-auction/api db:seed",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "tsc-alias": "^1.8.11",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
